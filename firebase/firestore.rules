rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the requesting user is the document owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper: check user role (requires a /users/{uid} doc with a "role" field)
    function hasRole(role) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Users collection: users can read/write their own data; admins can read/write all
    match /users/{userId} {
      allow read, write: if isOwner(userId) || hasRole('admin');
      allow create: if isAuthenticated();
    }

    // Patients collection: any authenticated user can CRUD
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if hasRole('admin');
    }

    // Visits collection
    match /visits/{visitId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if hasRole('admin');
    }

    // Reminders collection
    match /reminders/{reminderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if hasRole('admin');
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if hasRole('admin');
    }

    // Schemes collection (read-only for non-admins)
    match /schemes/{schemeId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }

    // Medical documents storage
    match /medical_documents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if hasRole('admin');
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}