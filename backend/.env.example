# MedAssist AI - Environment Configuration
# Copy this to .env and fill in your values

# Application
APP_NAME=MedAssist AI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://medassist-ai.web.app"]

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-001
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Firebase
# Option A: Set FIREBASE_SERVICE_ACCOUNT_PATH to point to your serviceAccountKey.json file
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option B: Set individual fields below
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=medical_knowledge

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT=100/minute
MAX_UPLOAD_SIZE=10485760

# Google Maps (for Nearby Hospitals feature)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Feature Flags
ENABLE_VOICE=true
ENABLE_OCR=true
ENABLE_EMERGENCY=true
ENABLE_MEDICINE_SCANNER=true
